<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:ClippyAI.ViewModels"
    xmlns:models="clr-namespace:ClippyAI.Models"
    x:Class="ClippyAI.Views.ConfigurationDialog"
    x:DataType="vm:ConfigurationDialogViewModel"
    x:Name="ConfigurationWindow"
    xmlns:resources="clr-namespace:ClippyAI.Resources"
    Title="{x:Static resources:Resources.Configuration}"
    Width="1000" Height="1100"
    WindowStartupLocation="CenterScreen"
    TransparencyLevelHint="AcrylicBlur"
    Background="Transparent"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaTitleBarHeightHint="-1"
    Topmost="True"
    CanResize="True"
    ShowInTaskbar="False">

    <Grid RowDefinitions="*,Auto" Background="#ff333333">
        <Grid.Styles>
            <Style Selector="TabItem">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="MinHeight" Value="45"/>
            </Style>
            <Style Selector="Label">
                <Setter Property="Margin" Value="0,10,0,2"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="12.5"/>
            </Style>
            <Style Selector="TextBox">
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style Selector="ComboBox">
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style Selector="HeaderedContentControl">
                <Setter Property="Template">
                        <ControlTemplate>
                            <StackPanel Margin="0,0,50,10">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="{TemplateBinding Header}" 
                                                FontSize="14" 
                                                FontWeight="Bold" 
                                                Foreground="#FF007ACC"
                                                VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border BorderBrush="#33FFFFFF" 
                                        BorderThickness="0,1,0,0" 
                                        Margin="0,0,0,15"/>
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </StackPanel>
                        </ControlTemplate>
                </Setter>
            </Style>
        </Grid.Styles>
        <!-- Main content -->
        <TabControl Grid.Row="0" Margin="0,0,0,10" TabStripPlacement="Left">
            <!-- General Settings Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:Resources.General}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <HeaderedContentControl Header="{x:Static resources:Resources.AIProviderSettings}">
                            <StackPanel>
                                <Label Content="{x:Static resources:Resources.AIProvider}"/>
                                <ComboBox ItemsSource="{Binding AiProviderItems}" SelectedItem="{Binding AiProvider}" 
                                          ToolTip.Tip="{x:Static resources:Resources.AIProviderDescription}"/>
                                
                                <!-- Test Connection Section -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Command="{Binding TestConnectionCommand}"
                                            IsEnabled="{Binding !GeneralTestInProgress}"
                                            Margin="0,0,10,0"
                                            ToolTip.Tip="{x:Static resources:Resources.TestConnectionDescription}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static resources:Resources.TestConnection}"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Text="{x:Static resources:Resources.Testing}" 
                                               IsVisible="{Binding GeneralTestInProgress}"
                                               VerticalAlignment="Center"
                                               Foreground="Orange"/>
                                </StackPanel>
                                
                                <Border Background="#33000000" 
                                        CornerRadius="4" 
                                        Padding="10"
                                        Margin="0,10,0,0"
                                        IsVisible="{Binding GeneralTestResult, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="{Binding GeneralTestResult}" 
                                               TextWrapping="Wrap"
                                               Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="{x:Static resources:Resources.OllamaSettings}">
                            <StackPanel>
                                <Label Content="{x:Static resources:Resources.OllamaUrl}"/>
                                <TextBox Text="{Binding OllamaUrl}" 
                                         ToolTip.Tip="{x:Static resources:Resources.OllamaUrlDescription}"/>
                            </StackPanel>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="{x:Static resources:Resources.OpenAISettings}">
                            <StackPanel>
                                <Label Content="{x:Static resources:Resources.OpenAIApiKey}"/>
                                <TextBox Text="{Binding OpenAIApiKey}" PasswordChar="*"
                                         ToolTip.Tip="{x:Static resources:Resources.OpenAIApiKeyDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.OpenAIBaseUrl}"/>
                                <TextBox Text="{Binding OpenAIBaseUrl}" 
                                         ToolTip.Tip="{x:Static resources:Resources.OpenAIBaseUrlDescription}"/>
                            </StackPanel>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="{x:Static resources:Resources.DefaultModel}">
                            <StackPanel>
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,10">
                                    <ComboBox ItemsSource="{Binding ModelItems}" SelectedItem="{Binding OllamaModel}" 
                                              ToolTip.Tip="{x:Static resources:Resources.SelectModelDescription}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0">
                                        <Button Command="{Binding AddModelCommand}" Margin="2"
                                                ToolTip.Tip="{x:Static resources:Resources.PullModelDescription}">
                                            <TextBlock Text="&#xf019;" FontFamily="avares://ClippyAI/Assets/fontawesome/otfs/Font Awesome 6 Free-Solid-900.otf#Font Awesome 6"/>
                                        </Button>
                                        <Button Command="{Binding DeleteModelCommand}" Margin="2"
                                                ToolTip.Tip="{x:Static resources:Resources.DeleteModelDescription}">
                                            <TextBlock Text="&#xf2ed;" FontFamily="avares://ClippyAI/Assets/fontawesome/otfs/Font Awesome 6 Free-Solid-900.otf#Font Awesome 6"/>
                                        </Button>
                                        <Button Command="{Binding RefreshModelsCommand}" Margin="2"
                                                ToolTip.Tip="{x:Static resources:Resources.RefreshModelListDescription}">
                                            <TextBlock Text="&#xf2f1;" FontFamily="avares://ClippyAI/Assets/fontawesome/otfs/Font Awesome 6 Free-Solid-900.otf#Font Awesome 6"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="{x:Static resources:Resources.General}">
                            <StackPanel>
                                <Label Content="{x:Static resources:Resources.Language}"/>
                                <ComboBox ItemsSource="{Binding LanguageItems}" SelectedItem="{Binding DefaultLanguage}" 
                                          ToolTip.Tip="{x:Static resources:Resources.DefaultLanguageDescription}"/>
                                
                                <CheckBox IsChecked="{Binding AutoMode}" Content="{x:Static resources:Resources.AutoMode}" Margin="0,10,0,10"
                                          ToolTip.Tip="{x:Static resources:Resources.AutoModeDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.DefaultTask}"/>
                                <ComboBox ItemsSource="{Binding AvailableTasks}" SelectedItem="{Binding DefaultTask}" 
                                          ToolTip.Tip="{x:Static resources:Resources.DefaultTaskDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.SystemPrompt}"/>
                                <TextBox Text="{Binding SystemPrompt}" Height="150" TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         ToolTip.Tip="{x:Static resources:Resources.SystemPromptDescription}"/>
                            </StackPanel>
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Embeddings Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:Resources.Embeddings}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <HeaderedContentControl Header="{x:Static resources:Resources.VectorDatabaseSettings}">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding UseEmbeddings}" Content="{x:Static resources:Resources.UseEmbeddings}" Margin="0,0,0,10"
                                          ToolTip.Tip="{x:Static resources:Resources.UseEmbeddingsDescription}"/>
                                
                                <CheckBox IsChecked="{Binding StoreAllResponses}" Content="{x:Static resources:Resources.StoreAllResponses}" Margin="0,0,0,10"
                                          ToolTip.Tip="{x:Static resources:Resources.StoreAllResponsesDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.PostgreSQLConnectionString}"/>
                                <TextBox Text="{Binding PostgreSqlConnection}" Height="60" TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         ToolTip.Tip="{x:Static resources:Resources.PostgreSQLConnectionStringDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.PostgresOllamaUrl}"/>
                                <TextBox Text="{Binding PostgresOllamaUrl}" 
                                         ToolTip.Tip="{x:Static resources:Resources.PostgresOllamaUrlDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.EmbeddingModel}"/>
                                <TextBox Text="{Binding EmbeddingModel}" 
                                         ToolTip.Tip="{x:Static resources:Resources.EmbeddingModelDescription}" 
                                         IsEnabled="{Binding UseEmbeddings}"/>
                                
                                <Label Content="{x:Static resources:Resources.Threshold}"/>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                                    <Slider Value="{Binding Threshold}" Minimum="-1" Maximum="1" 
                                            TickFrequency="0.1" ToolTip.Tip="{x:Static resources:Resources.ThresholdDescription}"/>
                                    <TextBox Grid.Column="1" Text="{Binding Threshold}" Width="60" Margin="10,0,0,0"/>
                                </Grid>
                                
                                <Button Content="{x:Static resources:Resources.ClearDatabase}" Command="{Binding ClearEmbeddingsCommand}"
                                        HorizontalAlignment="Left" Margin="0,10,0,10"
                                        ToolTip.Tip="{x:Static resources:Resources.ClearDatabaseDescription}"/>
                                
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                                    <Label Content="{x:Static resources:Resources.EmbeddingsCount}" VerticalAlignment="Center" Margin="0"/>
                                    <Border Background="#33000000" CornerRadius="4" Padding="8,4" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding EmbeddingsCount}" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Vision Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:Resources.VisionTab}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <HeaderedContentControl Header="{x:Static resources:Resources.VisionSettings}">
                            <StackPanel>
                                <Label Content="{x:Static resources:Resources.VideoDevice}"/>
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <ComboBox ItemsSource="{Binding VideoDevices}" SelectedItem="{Binding VideoDevice}" 
                                              ToolTip.Tip="{x:Static resources:Resources.VideoDeviceDescription}"/>
                                    <Button Grid.Column="1" Content="{x:Static resources:Resources.Refresh}" Command="{Binding RefreshVideoDevicesCommand}" 
                                            Margin="4,0,0,8" ToolTip.Tip="{x:Static resources:Resources.RefreshVideoDevicesDescription}"/>
                                    <Button Grid.Column="2" Content="{x:Static resources:Resources.ViewCamera}" Command="{Binding ShowCamera}" 
                                            Margin="4,0,0,8" ToolTip.Tip="{x:Static resources:Resources.ViewCameraDescription}"/>
                                </Grid>
                            </StackPanel>
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- System Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:Resources.SystemTab}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <HeaderedContentControl Header="{x:Static resources:Resources.SystemSettings}">
                            <StackPanel>
                                <Label Content="{x:Static resources:Resources.LinuxKeyboardDevice}"/>
                                <TextBox Text="{Binding LinuxKeyboardDevice}" 
                                         ToolTip.Tip="{x:Static resources:Resources.LinuxKeyboardDeviceDescription}"/>
                                
                                <Button Content="{x:Static resources:Resources.ConfigureHotkeyDevice}" Command="{Binding ConfigureHotkeyDeviceCommand}"
                                        HorizontalAlignment="Left" Margin="0,10,0,0"
                                        ToolTip.Tip="{x:Static resources:Resources.ConfigureHotkeyDeviceDescription}"/>
                            </StackPanel>
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- SSH Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:Resources.SSH}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <HeaderedContentControl Header="{x:Static resources:Resources.SSHTunnelSettings}">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding UseSSH}" Content="{x:Static resources:Resources.EnableSSHTunneling}" Margin="0,0,0,10"
                                          ToolTip.Tip="{x:Static resources:Resources.EnableSSHTunnelingDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.SSHUsername}"/>
                                <TextBox Text="{Binding SshUsername}" 
                                         ToolTip.Tip="{x:Static resources:Resources.SSHUsernameDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.SSHServer}"/>
                                <TextBox Text="{Binding SshServerUrl}" 
                                         ToolTip.Tip="{x:Static resources:Resources.SSHServerDescription}"/>
                                
                                <Grid ColumnDefinitions="*,*">
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <Label Content="{x:Static resources:Resources.SSHPort}"/>
                                        <TextBox Text="{Binding SshPort}" 
                                                 ToolTip.Tip="{x:Static resources:Resources.SSHPortDescription}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <Label Content="{x:Static resources:Resources.LocalTunnel}"/>
                                        <TextBox Text="{Binding SshLocalTunnel}" 
                                                 ToolTip.Tip="{x:Static resources:Resources.LocalTunnelDescription}"/>
                                    </StackPanel>
                                </Grid>

                                <Label Content="{x:Static resources:Resources.RemoteTunnel}"/>
                                <TextBox Text="{Binding SshRemoteTunnel}" 
                                         ToolTip.Tip="{x:Static resources:Resources.RemoteTunnelDescription}"/>
                                
                                <Label Content="{x:Static resources:Resources.PrivateKeyFile}"/>
                                <TextBox Text="{Binding SshPrivateKeyFile}" 
                                         ToolTip.Tip="{x:Static resources:Resources.PrivateKeyFileDescription}"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                    <Button Content="{x:Static resources:Resources.TestSSHConnection}" 
                                            Command="{Binding TestSSHConnectionCommand}"
                                            IsEnabled="{Binding !SshTestInProgress}"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="{x:Static resources:Resources.Testing}" 
                                               IsVisible="{Binding SshTestInProgress}"
                                               VerticalAlignment="Center"
                                               Foreground="Orange"/>
                                </StackPanel>
                                
                                <Border Background="#33000000" 
                                        CornerRadius="4" 
                                        Padding="10"
                                        Margin="0,10,0,0"
                                        IsVisible="{Binding SshTestResult, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="{Binding SshTestResult}" 
                                               TextWrapping="Wrap"
                                               Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Task Configurations Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:Resources.TasksTab}"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid RowDefinitions="*,Auto" Margin="10">
                    <Grid Grid.Row="0" ColumnDefinitions="280,*">
                        <!-- Left panel - Task list -->
                        <Border Grid.Column="0" Background="#11FFFFFF" CornerRadius="4" Margin="0,0,10,0" Padding="10">
                            <StackPanel>
                                <Label Content="{x:Static resources:Resources.Tasks}" Margin="0,0,0,10"/>
                                <ListBox ItemsSource="{Binding TaskConfigurations}" 
                                         SelectedItem="{Binding SelectedTaskConfiguration}"
                                         Height="400" Margin="0,0,0,10">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:TaskConfiguration">
                                            <TextBlock Text="{Binding TaskName}" Padding="5"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <Label Content="{x:Static resources:Resources.NewTaskName}"/>
                                <TextBox Text="{Binding NewTaskName}" />
                                <UniformGrid Columns="2" Margin="0,5,0,0">
                                    <Button Content="{x:Static resources:Resources.Add}" Command="{Binding AddNewTaskCommand}" HorizontalAlignment="Stretch" Margin="2"/>
                                    <Button Content="{x:Static resources:Resources.Delete}" Command="{Binding DeleteTaskCommand}" HorizontalAlignment="Stretch" Margin="2"/>
                                </UniformGrid>
                                <Button Content="{x:Static resources:Resources.RestoreDefault}"
                                        Command="{Binding RestoreDefaultTasksCommand}" 
                                        HorizontalAlignment="Stretch" 
                                        Margin="2,5,2,0"
                                        ToolTip.Tip="{x:Static resources:Resources.RestoreDefaultTasksDescription}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Right panel - Task details -->
                        <Border Grid.Column="1" Background="#11FFFFFF" CornerRadius="4" Padding="15">
                            <ContentControl Content="{Binding SelectedTaskConfiguration}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate x:DataType="models:TaskConfiguration">
                                        <ScrollViewer>
                                            <StackPanel>
                                                <HeaderedContentControl Header="{x:Static resources:Resources.TaskConfiguration}">
                                                    <StackPanel>
                                                        <Label Content="{x:Static resources:Resources.TaskName}"/>
                                                        <TextBox Text="{Binding TaskName}" IsReadOnly="True" Background="#22000000"/>
                                                        
                                                        <Label Content="{x:Static resources:Resources.Prompt}"/>
                                                        <TextBox Text="{Binding SystemPrompt}" Height="120" 
                                                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                                                        
                                                        <Label Content="{x:Static resources:Resources.Model}"/>
                                                        <ComboBox ItemsSource="{x:Static vm:ConfigurationDialogViewModel.AvailableModels}" 
                                                                  SelectedItem="{Binding Model}" 
                                                                  ToolTip.Tip="{x:Static resources:Resources.ModelDescription}"/>
                                                        
                                                        <CheckBox IsChecked="{Binding IsImageTask}"
                                                                  Content="{x:Static resources:Resources.IsImageTask}"
                                                                  Margin="0,10,0,10"
                                                                  ToolTip.Tip="{x:Static resources:Resources.IsImageTaskDescription}"/>
                                                        
                                                        <StackPanel IsVisible="{Binding IsImageTask}">
                                                            <Label Content="{x:Static resources:Resources.ImageSource}"/>
                                                            <ComboBox ItemsSource="{x:Static vm:ConfigurationDialogViewModel.ImageSources}"
                                                                      SelectedItem="{Binding ImageSource}"
                                                                      ToolTip.Tip="{x:Static resources:Resources.ImageSourceDescription}"/>
                                                        </StackPanel>

                                                        <Border Background="#11FFFFFF" CornerRadius="4" Padding="10" Margin="0,15,0,0">
                                                            <Grid ColumnDefinitions="*,1.5*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                                                <Label Grid.Row="0" Grid.Column="0" Content="{x:Static resources:Resources.Temperature}" VerticalAlignment="Center"/>
                                                                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,60" Margin="0,5">
                                                                    <Slider Value="{Binding Temperature}" Minimum="0" Maximum="2"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding Temperature}" Margin="10,0,0,0"/>
                                                                </Grid>
                                                                
                                                                <Label Grid.Row="1" Grid.Column="0" Content="{x:Static resources:Resources.MaxLength}" VerticalAlignment="Center"/>
                                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MaxLength}" HorizontalAlignment="Left" Width="100"/>
                                                                
                                                                <Label Grid.Row="2" Grid.Column="0" Content="{x:Static resources:Resources.TopP}" VerticalAlignment="Center"/>
                                                                <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,60" Margin="0,5">
                                                                    <Slider Value="{Binding TopP}" Minimum="0" Maximum="1"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding TopP}" Margin="10,0,0,0"/>
                                                                </Grid>
                                                                
                                                                <Label Grid.Row="3" Grid.Column="0" Content="{x:Static resources:Resources.TopK}" VerticalAlignment="Center"/>
                                                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TopK}" HorizontalAlignment="Left" Width="100"/>
                                                                
                                                                <Label Grid.Row="4" Grid.Column="0" Content="{x:Static resources:Resources.RepeatPenalty}" VerticalAlignment="Center"/>
                                                                <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,60" Margin="0,5">
                                                                    <Slider Value="{Binding RepeatPenalty}" Minimum="0.5" Maximum="2"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding RepeatPenalty}" Margin="10,0,0,0"/>
                                                                </Grid>
                                                                
                                                                <Label Grid.Row="5" Grid.Column="0" Content="{x:Static resources:Resources.ContextLength}" VerticalAlignment="Center"/>
                                                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding NumCtx}" HorizontalAlignment="Left" Width="100"/>
                                                            </Grid>
                                                        </Border>
                                                    </StackPanel>
                                                </HeaderedContentControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <Border Grid.Row="1" Background="#22000000" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="SaveButton" Classes="accent" Margin="0,0,10,0" Width="120" IsDefault="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:Resources.Save}"/>
                    </StackPanel>
                </Button>
                <Button Name="CloseButton" Width="120" IsCancel="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:Resources.Close}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>