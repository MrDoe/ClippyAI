{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "msbuild",
            "command": "dotnet",
            "type": "process",
            "args": [
                "msbuild",
                "${workspaceFolder}/ClippyAI.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/ClippyAI.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-debug",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/ClippyAI.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign",
                "/p:Configuration=Debug"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/ClippyAI.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign",
                "/p:Configuration=Release"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish-windows",
            "dependsOn": ["build-release"],
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/ClippyAI/ClippyAI.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign",
                "/p:TargetFramework=net10.0-windows10.0.17763.0"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish-windows-msi",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Installer/ClippyAI.Installer.wixproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign",
                "/p:Configuration=Release"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish-windows-msi-release",
            "dependsOn": ["publish-windows-msi"],
            "dependsOrder": "sequence",
            "command": "pwsh",
            "type": "process",
            "args": [
                "-NoLogo",
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/publish-windows-msi-release.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "publish-linux-deb",
            "dependsOn": "",
            "command": "dotnet",
            "type": "process",
            "args": [
                "msbuild",
                "${workspaceFolder}/ClippyAI/ClippyAI.csproj",
                "/t:CreateDeb",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign",
                "/p:Configuration=Release"
            ],
            "options":{
                "cwd": "${workspaceFolder}/ClippyAI"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish-linux-rpm",
            "dependsOn": "",
            "command": "dotnet",
            "type": "process",
            "args": [
                "msbuild",
                "${workspaceFolder}/ClippyAI/ClippyAI.csproj",
                "/t:CreateRpm",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign",
                "/p:Configuration=Release"
            ],
            "options":{
                "cwd": "${workspaceFolder}/ClippyAI"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish-linux-tar",
            "dependsOn": "",
            "command": "dotnet",
            "type": "process",
            "args": [
                "msbuild",
                "${workspaceFolder}/ClippyAI/ClippyAI.csproj",
                "/t:CreateTarball",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign",
                "/p:Configuration=Release"
            ],
            "options":{
                "cwd": "${workspaceFolder}/ClippyAI"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish-linux",
            "dependsOn": ["publish-linux-deb", "publish-linux-rpm", "publish-linux-tar"],
            "dependsOrder": "sequence",
            "command": "bash",
            "type": "process",
            "args": [
                "${workspaceFolder}/scripts/upload-linux-release-assets.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "run",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/ClippyAI/ClippyAI.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/ClippyAI/ClippyAI.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}